PORT=3001
SESSION_SECRET=change-me-to-random-string

# Source Salesforce Org (the one with MaicaCare + MaicaBilling packages)
SF_SOURCE_CLIENT_ID=
SF_SOURCE_CLIENT_SECRET=
SF_SOURCE_CALLBACK_URL=http://localhost:3001/oauth/source/callback
SF_SOURCE_LOGIN_URL=https://login.salesforce.com

# Target Salesforce Org (the one with the new merged Maica package)
SF_TARGET_CLIENT_ID=
SF_TARGET_CLIENT_SECRET=
SF_TARGET_CALLBACK_URL=http://localhost:3001/oauth/target/callback
SF_TARGET_LOGIN_URL=https://login.salesforce.com

# Railway Postgres (auto-provided by Railway when you add Postgres plugin)
# DATABASE_URL=

# For Railway: use your app domain for callbacks, e.g.:
# SF_SOURCE_CALLBACK_URL=https://your-app.up.railway.app/oauth/source/callback
# SF_TARGET_CALLBACK_URL=https://your-app.up.railway.app/oauth/target/callback
